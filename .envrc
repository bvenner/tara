eval "$(devenv direnvrc)"

use devenv

# Load SOPS-encrypted secrets
load_encrypted_env() {
  local file="$1"
  [ ! -f "$file" ] && return
  
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    [[ "$line" == \#* ]] && continue
    export "$line"
  done < <(sops -d "$file")
}

load_encrypted_env .enc.env
